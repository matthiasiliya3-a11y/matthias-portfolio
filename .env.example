# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Analytics
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Email Service (if using EmailJS)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Contact Information
VITE_CONTACT_EMAIL=hello@matthias.dev
VITE_CONTACT_PHONE=+234800000000
VITE_WHATSAPP_NUMBER=2348000000000

# Social Media Links
VITE_GITHUB_URL=https://github.com/matthias
VITE_LINKEDIN_URL=https://linkedin.com/in/matthias
VITE_INSTAGRAM_URL=https://instagram.com/matthias
VITE_TWITTER_URL=https://twitter.com/matthias
VITE_FACEBOOK_URL=https://facebook.com/matthias

# API Endpoints (if applicable)
VITE_API_BASE_URL=https://api.example.com
VITE_API_KEY=your_api_key_here

# Feature Flags
VITE_ENABLE_CONTACT_FORM=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ANIMATIONS=true
